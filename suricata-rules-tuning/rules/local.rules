# 1. ICMP Ping Detection
alert icmp any any -> any any (msg:"[CA_TEST] ICMP Ping Detected"; sid:1000001; rev:1;)

# 2. HTTP Traffic Detection
alert http any any -> any any (msg:"[CA_TEST] HTTP Traffic Detected"; sid:1000002; rev:1;)

# 3. Nmap SYN Scan Detection
alert tcp any any -> any any (msg:"[CA_TEST] Nmap SYN Scan Detected"; flags:S; sid:1000005; rev:1;)

# 4. Nmap Port Scan Activity
alert tcp any any -> any any (msg:"[CA_TEST] Nmap Port Scan Activity"; flags:S; sid:1000007; rev:1;)

# 5. Multiple Port Connection Attempt
alert tcp any any -> any any (msg:"[CA_TEST] Multiple Port Connection Attempt"; flags:S; sid:1000008; rev:1;)

# 6. SSH Connection Attempt
alert tcp any any -> any 22 (msg:"[CA_TEST] SSH Connection Attempt"; sid:1000010; rev:1;)

# 7. HTTPS Traffic Detection
alert tls any any -> any any (msg:"[CA_TEST] HTTPS Traffic Detected"; sid:1000012; rev:1;)

# 8. DNS Query Detection
alert udp any any -> any 53 (msg:"[CA_TEST] DNS Query Detected"; sid:1000013; rev:1;)

# 9. FTP Connection Attempt
alert tcp any any -> any 21 (msg:"[CA_TEST] FTP Connection Attempt"; sid:1000014; rev:1;)

# 10. MySQL Connection Attempt
alert tcp any any -> any 3306 (msg:"[CA_TEST] MySQL Connection Attempt"; sid:1000015; rev:1;)

# 11. Telnet Connection Attempt (Insecure)
alert tcp any any -> any 23 (msg:"[CA_TEST] Telnet Connection Attempt"; sid:1000016; rev:1;)

# 12. Simple Port Scan (Any TCP)
alert tcp any any -> any any (msg:"[CA_TEST] TCP Port Scan Detected"; flags:S; sid:1000017; rev:1;)
